rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Profiles ---
    match /users/{userId} {
      // Allow read for authenticated users (to verify stats)
      allow read: if isSignedIn();
      
      // Allow creation/update by owner or server
      allow write: if isOwner(userId) || request.auth == null;
    }

    // --- API Key Mappings ---
    match /apiKeys/{key} {
      // Allow read by anyone (primarily for the API server)
      allow read: if true;
      
      // Create/Delete by owner
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }
  }
}
